// GitHub Codespaces dev container for cli-pulse-desktop (Tauri 2 + React/Vite).
// Gives a browser-based Linux toolchain to develop, test, and BUILD the Linux
// bundles (.deb / .rpm / .AppImage) — the target your Mac can't build natively.
// Mirrors the Ubuntu 24.04 + webkit deps used in .github/workflows/release.yml.
//
// Usage in a Codespace:
//   npm run dev                  # Vite frontend dev server (port forwarded)
//   npm run tauri build          # produce Linux bundles in src-tauri/target/release/bundle
//   cargo test --manifest-path src-tauri/Cargo.toml
//   npm test                     # vitest
//
// NOTE: Windows builds stay in CI (release.yml, windows-latest, nsis) — a Linux
// Codespace cannot build Windows. The Tauri GUI window itself needs a display;
// builds + frontend dev + tests run headless here without one.
{
  "name": "cli-pulse-desktop · Tauri/Linux",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/rust:1": {}
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y libwebkit2gtk-4.1-dev libayatana-appindicator3-dev librsvg2-dev libssl-dev patchelf xdg-utils build-essential curl wget file",
  "postCreateCommand": "npm install",
  "forwardPorts": [1420, 5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "tauri-apps.tauri-vscode",
        "rust-lang.rust-analyzer",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "vscode"
}
