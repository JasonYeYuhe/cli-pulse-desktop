#!/usr/bin/env bash
# pre-push: run the same gates CI runs, locally, before code leaves
# the laptop. Catches:
#   - rustfmt drift
#   - clippy errors
#   - Rust unit + integration tests (host-TZ-stable ones, at least)
#   - frontend type / build errors
#
# Skip with `git push --no-verify` if you're consciously pushing
# work-in-progress.
#
# Original motivation: v0.2.3 first push had a host-TZ-dependent
# integration test that passed on my dev Mac (JST) and failed on all
# 4 CI runners (UTC). A 30-second pre-push gate doesn't catch that
# specific case, but it does catch the routine fmt / clippy / test
# regressions that should never reach CI. Net delta: faster
# iteration, less wasted CI minutes.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

GREEN=$'\033[0;32m'; RED=$'\033[0;31m'; DIM=$'\033[2m'; RESET=$'\033[0m'

step() {
    printf '\n%s== %s ==%s\n' "$DIM" "$1" "$RESET"
}

fail() {
    printf '\n%s✘ pre-push failed at: %s%s\n' "$RED" "$1" "$RESET"
    printf '   re-run with %sgit push --no-verify%s if intentional.\n' "$DIM" "$RESET"
    exit 1
}

step "rustfmt"
( cd src-tauri && cargo fmt --all -- --check ) || fail "cargo fmt"

# v0.9.1a regression guard against the v0.8.0 BEX64 root cause.
#
# v0.8.0 crashed on launch with "panic: there is no reactor running,
# must be called from the context of a Tokio 1.x runtime" because
# `spawn_agent_loop` used `tokio::spawn` from inside Tauri's `setup`
# hook, which runs OUTSIDE any tokio runtime context. The fix is
# `tauri::async_runtime::spawn`, which dispatches via Tauri's
# internal handle.
#
# This step fails the pre-push if any Rust file under src-tauri/src/
# matches `tokio::spawn(` AND is not inside a `#[cfg(test)]` module.
# Test-time code is allowed (and unavoidable, since `#[tokio::test]`
# expands to constructs that include `tokio::spawn`).
#
# To suppress on a legitimate non-test call site, add `// @allow tokio-spawn`
# on the same line.
step "tokio::spawn regression guard"
TOKIO_SPAWN_HITS=$(grep -rn --include='*.rs' 'tokio::spawn(' src-tauri/src/ 2>/dev/null \
    | grep -v '@allow tokio-spawn' \
    | grep -v '/\*\* tokio::spawn' \
    | grep -v 'cfg(test)' || true)
# Drop hits that fall inside test modules / tokio::test attribute.
# Heuristic: filter by file+line — if line is in mod tests, ignore.
# Easier: rg "tokio::spawn\(" --no-config -t rust src-tauri/src/ -B 2 \
# would let us see surrounding context. Simpler — just drop matches
# where the full file path's containing function is annotated with
# #[tokio::test] OR is in a `mod tests` block. For now, keep it
# conservative: any production hit fails the pre-push, and devs
# annotate with `// @allow tokio-spawn` if it's intentional.
if [ -n "$TOKIO_SPAWN_HITS" ]; then
    # Check if all hits are within `mod tests` or `#[tokio::test]`
    # blocks by inspecting the file context around each line.
    PRODUCTION_HITS=""
    while IFS= read -r hit; do
        FILE=$(echo "$hit" | cut -d: -f1)
        LINE=$(echo "$hit" | cut -d: -f2)
        # Look at the 50 lines preceding the hit. If we see
        # `mod tests {` or `#[tokio::test]` more recently than any
        # `mod ` declaration, the hit is in a test context.
        CONTEXT=$(sed -n "$((LINE > 50 ? LINE - 50 : 1)),${LINE}p" "$FILE")
        # Match #[tokio::test], #[tokio::test(...)], mod tests, #[cfg(test)]
        if echo "$CONTEXT" | grep -qE '#\[tokio::test|mod tests \{|#\[cfg\(test\)\]'; then
            continue
        fi
        PRODUCTION_HITS="${PRODUCTION_HITS}${hit}\n"
    done <<< "$TOKIO_SPAWN_HITS"

    if [ -n "$PRODUCTION_HITS" ]; then
        echo
        printf 'Found bare tokio::spawn in production code:\n'
        printf '%b' "$PRODUCTION_HITS"
        echo
        echo "v0.8.0 root cause: tokio::spawn from Tauri setup hook = panic-abort."
        echo "Use tauri::async_runtime::spawn instead, OR add '// @allow tokio-spawn'"
        echo "on the line if you've verified the call site has tokio runtime context."
        fail "tokio::spawn regression guard"
    fi
fi

step "clippy"
( cd src-tauri && cargo clippy --all-targets -- -D warnings ) || fail "cargo clippy"

step "tests (cargo test)"
( cd src-tauri && cargo test --quiet ) || fail "cargo test"

step "frontend tsc + vite build"
npm run build > /tmp/cli-pulse-frontend-build.log 2>&1 || {
    echo "  frontend build failed — last 20 lines:"
    tail -20 /tmp/cli-pulse-frontend-build.log
    fail "frontend build"
}

step "frontend tests (vitest)"
npm test > /tmp/cli-pulse-frontend-tests.log 2>&1 || {
    echo "  frontend tests failed — last 30 lines:"
    tail -30 /tmp/cli-pulse-frontend-tests.log
    fail "vitest"
}

printf '\n%s✓ pre-push gates green — pushing%s\n' "$GREEN" "$RESET"
